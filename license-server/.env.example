# Copiez en .env (en local) ou configurez ces variables sur Render.
# Générez la clé privée avec : npm run keygen
LICENSE_PRIVATE_KEY=collez_ici_la_cle_privee_base64
# Clés valides séparées par des virgules (pour tester l'activation)
LICENSE_KEYS=HN-TEST-0001
# Secret pour créer/révoquer des clés via /admin
ADMIN_SECRET=changez-moi
PRODUCT=HydroNet
# Clés démo multi-postes (optionnel)
LICENSE_KEYS_MULTI=HN-DEMO-2026
# Persistance (production) — Upstash Redis REST. Sans ça : stockage en mémoire.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
